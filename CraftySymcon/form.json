{
  "elements": [
    {
      "type": "ValidationTextBox",
      "name": "BaseURL",
      "caption": "Crafty Base URL"
    },
    {
      "type": "PasswordTextBox",
      "name": "APIToken",
      "caption": "API Token"
    },
    {
      "type": "ExpansionPanel",
      "caption": "Legacy Crafty (UUID)",
      "items": [
        {
          "type": "ValidationTextBox",
          "name": "ServerUUID",
          "caption": "Server UUID"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Crafty 4.x (numeric ID)",
      "items": [
        {
          "type": "NumberSpinner",
          "name": "ServerID",
          "caption": "Server ID"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Start Server",
      "onClick": "CRAFTY_StartServer($id);"
    },
    {
      "type": "Button",
      "caption": "Stop Server",
      "onClick": "CRAFTY_StopServer($id);"
    },
    {
      "type": "Button",
      "caption": "Restart Server",
      "onClick": "CRAFTY_RestartServer($id);"
    },
    {
      "type": "Button",
      "caption": "Update Stats",
      "onClick": "CRAFTY_UpdateStats($id);"
    }
  ]
}
